// grammar: test_grammar
// version: 1.0
// spec: Agents.md §3

root ::= "{" ws "\"direction\"" ws ":" ws direction "," ws "\"confidence\"" ws ":" ws number "," ws "\"reasoning\"" ws ":" ws string "}"
direction ::= "\"BULLISH\"" | "\"BEARISH\"" | "\"NEUTRAL\""
ws ::= [ \t\n]*
number ::= [0-9]+ "." [0-9]+ | [0-9]+
string ::= "\"" [^"]* "\""
