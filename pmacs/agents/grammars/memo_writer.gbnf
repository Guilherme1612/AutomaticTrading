// grammar: memo_writer
// version: 1.0
// spec: Agents.md §13

root ::= "{" ws "\"ticker\"" ws ":" ws string "," ws "\"verdict_line\"" ws ":" ws string "," ws "\"thesis_summary\"" ws ":" ws string "," ws "\"key_evidence\"" ws ":" ws string_array "," ws "\"key_risks\"" ws ":" ws string_array "," ws "\"conviction\"" ws ":" ws number "," ws "\"p_up\"" ws ":" ws number "," ws "\"p_flat\"" ws ":" ws number "," ws "\"p_down\"" ws ":" ws number ("," ws "\"ev_multiple\"" ws ":" ws number)? ("," ws "\"sizing_usd\"" ws ":" ws number)? "," ws "\"dissenting_personas\"" ws ":" ws string_array ("," ws "\"dissent_summary\"" ws ":" ws string)? ws "}"
ws ::= [ \t\n]*
number ::= "-"? [0-9]+ ("." [0-9]+)?
string ::= "\"" [^"]* "\""
string_array ::= "[" ws (string ("," ws string)*)? ws "]"
