 <script>
 // Ticker workspace tab switching (Source.md §16.6). No framework — plain DOM,
 // degrades to all-panels-visible if JS fails (panels default to .hidden except
 // fundamentals, so without JS only fundamentals shows; with JS, tabs reveal).
 (function () {
     var tabs = document.querySelectorAll('[data-ws-tab]');
     var panels = document.querySelectorAll('.ws-panel');
     if (!tabs.length) return;
     function activate(name) {
         panels.forEach(function (p) {
             p.classList.toggle('hidden', p.id !== 'ws-' + name);
         });
         tabs.forEach(function (b) {
             var on = b.getAttribute('data-ws-tab') === name;
             b.setAttribute('aria-selected', on ? 'true' : 'false');
             b.setAttribute('tabindex', on ? '0' : '-1');
+            // F-004: active state is now CSS-driven via [aria-selected="true"]
+            // in style.css. No class-toggling here; kept for backwards-compat
+            // with any custom rule that targets .bg-accent-soft on a button.
             b.classList.toggle('bg-accent-soft', on);
             b.classList.toggle('text-accent', on);
             b.classList.toggle('text-text-secondary', !on);
         });
         try { history.replaceState(null, '', '#' + name); } catch (e) {}
     }
     tabs.forEach(function (b) {
-         b.addEventListener('click', function () { activate(b.getAttribute('data-ws-tab')); });
+         b.addEventListener('click', function () { activate(b.getAttribute('data-ws-tab')); });
+         // F-002: keyboard navigation (Arrow / Home / End) per WAI-ARIA tab pattern.
+         b.addEventListener('keydown', function (e) {
+             var ids = Array.prototype.map.call(tabs, function (t) { return t.getAttribute('data-ws-tab'); });
+             var i = ids.indexOf(b.getAttribute('data-ws-tab'));
+             var next = -1;
+             if (e.key === 'ArrowRight') next = (i + 1) % tabs.length;
+             else if (e.key === 'ArrowLeft') next = (i - 1 + tabs.length) % tabs.length;
+             else if (e.key === 'Home') next = 0;
+             else if (e.key === 'End') next = tabs.length - 1;
+             if (next < 0) return;
+             e.preventDefault();
+             var target = tabs[next];
+             target.focus();
+             activate(target.getAttribute('data-ws-tab'));
+         });
     });
     // Deep link: /ticker/{ticker}#memo  -> open that tab.
     var initial = (location.hash || '').replace('#', '');
     if (initial && document.getElementById('ws-' + initial)) { activate(initial); }
     else { activate('fundamentals'); }
 })();
 </script>
