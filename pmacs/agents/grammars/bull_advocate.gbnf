// grammar: bull_advocate
// version: 1.0
// spec: Agents.md §11b

root ::= "{" ws "\"ticker\"" ws ":" ws string "," ws "\"target_persona\"" ws ":" ws target-persona "," ws "\"p_up\"" ws ":" ws number "," ws "\"p_flat\"" ws ":" ws number "," ws "\"p_down\"" ws ":" ws number "," ws "\"reasoning\"" ws ":" ws string "," ws "\"strongest_bear_counterpoint\"" ws ":" ws string "," ws "\"evidence_ids\"" ws ":" ws evidence-array ws "}"

target-persona ::= "\"macro_regime\"" | "\"catalyst_summarizer\"" | "\"moat_analyst\"" | "\"growth_hunter\"" | "\"insider_activity\"" | "\"short_interest\"" | "\"forensics\""

evidence-array ::= "[" ws string (ws "," ws string)* ws "]"

ws ::= [ \t\n\r]?

string ::= "\"" [^"\\]* "\""

number ::= "-"? ([0-9]+ ("." [0-9]+)?) | ("." [0-9]+)
