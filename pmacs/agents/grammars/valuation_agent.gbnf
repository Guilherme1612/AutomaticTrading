// grammar: valuation_agent
// version: 1.0
// spec: Agents.md §13b, Architecture.md §9.4b
//
// ValuationAgent emits bull/base/bear forward-valuation ASSUMPTIONS only — never
// a price. Post-arbitration; does NOT enter Arbitration. The deterministic
// ForwardValuationEngine consumes these assumptions.

root ::= "{" ws "\"ticker\"" ws ":" ws string ws "," ws "\"horizon_months\"" ws ":" ws number ws "," ws "\"bull\"" ws ":" ws scenario ws "," ws "\"base\"" ws ":" ws scenario ws "," ws "\"bear\"" ws ":" ws scenario ws "," ws "\"data_gaps\"" ws ":" ws string-array ws "," ws "\"evidence_ids\"" ws ":" ws evidence-array ws "}"

scenario ::= "{" ws "\"revenue_growth_path_pct\"" ws ":" ws number ws "," ws "\"margin_trajectory\"" ws ":" ws trajectory-val ws "," ws "\"margin_delta_pct\"" ws ":" ws number ws "," ws "\"ebitda_margin_at_horizon_pct\"" ws ":" ws number ws "," ws "\"acquisition_revenue_contribution_pct\"" ws ":" ws number ws "," ws "\"acquisition_confidence\"" ws ":" ws acq-conf-val ws "," ws "\"exit_multiple\"" ws ":" ws number ws "," ws "\"rationale\"" ws ":" ws string ws "," ws "\"probability_of_occurrence\"" ws ":" ws number ws "," ws "\"evidence_ids\"" ws ":" ws evidence-array ws "}"

trajectory-val ::= "\"COMPRESSING\"" | "\"EXPANDING\"" | "\"STABLE\""

acq-conf-val ::= "\"HIGH\"" | "\"MODERATE\"" | "\"LOW\"" | "\"NONE\""

string-array ::= "[" ws string (ws "," ws string)* ws "]" | "[" ws "]"

evidence-array ::= "[" ws string (ws "," ws string)* ws "]"

ws ::= [ \t\n\r]*

string ::= "\"" ([^"\\] | "\\" .)* "\""

number ::= "-"? ([0-9]+ ("." [0-9]+)?) | ("." [0-9]+)
