// grammar: memo_writer
// version: 2.0
// spec: Agents.md §13
//
// NOTE: This grammar matches the extended JSON format produced by _generate_full_memo()
// in pipeline.py and stored in memos.memo_json.  The field is "thesis" (not
// "thesis_summary") to match the DB schema and memo.html template.
//
// Because _generate_full_memo() uses a free-form LLM call (not grammar-constrained),
// this grammar documents the expected format for the MemoWriterRunner path.
// All fields after key_risks are optional to accommodate partial outputs.

root ::= "{" ws
  "\"verdict_line\"" ws ":" ws string ws "," ws
  "\"thesis\"" ws ":" ws string ws "," ws
  "\"key_evidence\"" ws ":" ws string_array ws "," ws
  "\"key_risks\"" ws ":" ws string_array
  (ws "," ws "\"fair_value\"" ws ":" ws number)?
  (ws "," ws "\"valuation_range\"" ws ":" ws object)?
  (ws "," ws "\"valuation_methodology\"" ws ":" ws string)?
  (ws "," ws "\"business_model\"" ws ":" ws string)?
  (ws "," ws "\"financial_snapshot\"" ws ":" ws object)?
  (ws "," ws "\"growth_drivers\"" ws ":" ws array)?
  (ws "," ws "\"competitive_position\"" ws ":" ws object)?
  (ws "," ws "\"risk_factors\"" ws ":" ws array)?
  (ws "," ws "\"catalyst_calendar\"" ws ":" ws array)?
  (ws "," ws "\"bear_case_response\"" ws ":" ws string)?
  (ws "," ws "\"crucible_severity\"" ws ":" ws number)?
  (ws "," ws "\"crucible_summary\"" ws ":" ws string)?
  (ws "," ws "\"crucible_attacks\"" ws ":" ws string_array)?
  (ws "," ws "\"agent_signals\"" ws ":" ws array)?
  (ws "," ws "\"position_sizing_note\"" ws ":" ws string)?
  (ws "," ws "\"p_up\"" ws ":" ws number)?
  (ws "," ws "\"p_flat\"" ws ":" ws number)?
  (ws "," ws "\"p_down\"" ws ":" ws number)?
  (ws "," ws "\"conviction\"" ws ":" ws number)?
  (ws "," ws "\"raw_text\"" ws ":" ws string)?
  (ws "," ws "\"dissenting_personas\"" ws ":" ws string_array)?
  (ws "," ws "\"dissent_summary\"" ws ":" ws string)?
  (ws "," ws "\"crucible_thesis_survives\"" ws ":" ws ("true" | "false"))?
  ws "}"

ws          ::= [ \t\n\r]*
number      ::= "-"? [0-9]+ ("." [0-9]+)?
string      ::= "\"" ([^"\\] | "\\" .)* "\""
string_array ::= "[" ws (string (ws "," ws string)*)? ws "]"
// Generic array and object — accept any JSON value to avoid over-constraining
value       ::= string | number | object | array | "true" | "false" | "null"
array       ::= "[" ws (value (ws "," ws value)*)? ws "]"
object      ::= "{" ws (string ws ":" ws value (ws "," ws string ws ":" ws value)*)? ws "}"
