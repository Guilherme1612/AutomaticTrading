{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "memo_writer",
  "description": "JSON Schema for memo_writer persona output (Agents.md §13, §16.9). Field is 'thesis' (NOT 'thesis_summary') to match the DB schema, memo.html template, and MemoWriterOutput Pydantic model.",
  "type": "object",
  "properties": {
    "ticker": {
      "type": "string"
    },
    "verdict_line": {
      "type": "string"
    },
    "thesis": {
      "type": "string"
    },
    "fair_value": {
      "type": "number"
    },
    "valuation_range": {
      "type": "object"
    },
    "valuation_methodology": {
      "type": "string"
    },
    "business_model": {
      "type": "string"
    },
    "financial_snapshot": {
      "type": "object"
    },
    "industry_kpis": {
      "type": "object"
    },
    "growth_drivers": {
      "type": "array"
    },
    "competitive_position": {
      "type": "object"
    },
    "risk_factors": {
      "type": "array"
    },
    "catalyst_calendar": {
      "type": "array"
    },
    "key_evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "key_risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "bear_case_response": {
      "type": "string"
    },
    "crucible_severity": {
      "type": "number"
    },
    "crucible_summary": {
      "type": "string"
    },
    "crucible_attacks": {
      "type": "array"
    },
    "crucible_thesis_survives": {
      "type": "boolean"
    },
    "agent_signals": {
      "type": "array"
    },
    "position_sizing_note": {
      "type": "string"
    },
    "p_up": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "p_flat": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "p_down": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "conviction": {
      "type": "number"
    },
    "ev_multiple": {
      "type": "number"
    },
    "sizing_usd": {
      "type": "number"
    },
    "dissenting_personas": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "dissent_summary": {
      "type": "string"
    },
    "bull_bear_debate": {
      "type": "object",
      "description": "Wave-2 advocate debate summary (Agents.md §16.9). Empty object when no debate context.",
      "properties": {
        "bull_case": { "type": "string" },
        "bear_case": { "type": "string" },
        "advocate_lean": {
          "type": "string",
          "enum": ["BULL", "BEAR", "BALANCED", "NEUTRAL"]
        },
        "reverse_dcf_gap": { "type": "string" }
      }
    },
    "what_would_change_my_mind": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Pre-registered falsification triggers (Agents.md §16.9)."
    },
    "reverse_dcf": {
      "type": "object",
      "description": "Serialized ReverseDcfResult injected by the orchestrator (deterministic, not LLM-produced)."
    },
    "scenario_price": {
      "type": "object",
      "description": "Serialized ScenarioPriceResult injected by the orchestrator (deterministic, not LLM-produced)."
    },
    "raw_text": {
      "type": "string"
    }
  },
  "required": [
    "ticker",
    "verdict_line",
    "thesis",
    "key_evidence",
    "key_risks",
    "conviction",
    "p_up",
    "p_flat",
    "p_down",
    "dissenting_personas"
  ]
}