# PMACS Environment Variables
# Copy this file to .env and fill in your values.
# Secrets are stored via macOS Keychain (keyring) — this file is for paths only.

# ── Paths ──────────────────────────────────────────────
# Data directory (databases, audit logs, heartbeat files)
# Default: /usr/local/var/pmacs
PMACS_DATA_DIR=/usr/local/var/pmacs

# Config directory (TOML + JSON config files)
# Default: ./config (relative to project root)
PMACS_CONFIG_DIR=./config

# ── API Keys (stored via keyring, NOT here) ────────────
# These are set via the wizard or keyring CLI:
#   keyring set pmacs.credentials alpaca_key
#   keyring set pmacs.credentials alpaca_secret
#   keyring set pmacs.credentials polygon_key
#   keyring set pmacs.credentials finnhub_api_key
#   keyring set pmacs.credentials fred_key
#   keyring set pmacs.credentials edgar_ua

# ── Services ───────────────────────────────────────────
# llama-server inference backend (pf-blocked from internet)
# Configured in config/model_registry.json
# PMACS_INFERENCE_URL=http://127.0.0.1:8080

# Qdrant vector database
# PMACS_QDRANT_URL=http://127.0.0.1:6333

# Nervous orchestration API + dashboard web UI (combined, loopback only)
# PMACS_NERVOUS_PORT=8000
