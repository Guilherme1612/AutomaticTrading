# AGENT-1 PROPOSAL — NOT APPLIED
# ============================================================================
# style.css additions for F-004 (CSS-driven tab active state), F-010
# (<details> chevron), F-011 (micro-label contrast), F-014 (eyebrow class).
# Anchor: insert these rules AFTER the existing "WCAG AA Focus" block at
# style.css:L1315-1325 to keep the focus rules together.
# ============================================================================

--- a/pmacs/web/static/style.css
+++ b/pmacs/web/static/style.css
@@ -1325,6 +1325,42 @@ button:focus-visible,
 a:focus-visible,
 input:focus-visible,
 select:focus-visible,
 textarea:focus-visible {
     outline: 2px solid var(--accent);
     outline-offset: 2px;
     border-radius: 2px;
 }
+
+/* ─── Workspace Tabs (F-004) ─────────────────────────────────────────── */
+/* Active state is data-attribute driven so it survives without JS. */
+.ws-tab {
+    transition: background 0.15s ease, color 0.15s ease;
+}
+.ws-tab:hover {
+    background: var(--surface-sunken);
+}
+.ws-tab[aria-selected="true"] {
+    background: var(--accent-soft);
+    color: var(--accent);
+}
+.ws-tab[aria-selected="true"]:hover {
+    filter: brightness(0.97);
+}
+
+/* ─── Persona Details Marker (F-010) ────────────────────────────────── */
+/* <details> open/closed chevron. Apply class="pm-details" to the <details>. */
+details.pm-details > summary { list-style: none; cursor: pointer; }
+details.pm-details > summary::-webkit-details-marker { display: none; }
+details.pm-details > summary::after {
+    content: '\25B8';
+    margin-left: auto;
+    padding-left: 0.5rem;
+    color: var(--text-muted);
+    transition: transform 0.2s ease;
+}
+details.pm-details[open] > summary::after {
+    transform: rotate(90deg);
+}
+
+/* ─── Eyebrow Micro-Label (F-011, F-014) ────────────────────────────── */
+/* Consolidates the 10px uppercase tracking-widest label pattern that
+   appears ~30 times on /ticker/{ticker}. Higher contrast than
+   text-text-muted at 10-12px to clear WCAG AA. */
+.pmacs-eyebrow {
+    font-size: 10px;
+    font-weight: 600;
+    text-transform: uppercase;
+    letter-spacing: 0.1em;
+    color: var(--text-secondary);
+}
